# Copy to .env and fill in. Also set these in Vercel (Project Settings → Environment Variables).
# PUBLIC_* are safe in the browser; SUPABASE_SECRET_KEY is server-only — never expose it.
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
