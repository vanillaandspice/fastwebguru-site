---
import Layout from '../layouts/Layout.astro';
import CTABlock from '../components/CTABlock.astro';
export const prerender = true;

const steps = [
  {
    n: '1',
    title: 'Get your free AI assessment',
    body: 'Hit the button below. Enter your name, email, website URL, and business type. We\'ll look at your site and send you a personalised snapshot — what\'s working, what isn\'t, and what the AI era specifically means for your type of business. No sales call. No commitment. Just useful information about the website you\'ve already got. Results in your inbox within 24 hours.',
    cta: true,
  },
  {
    n: '2',
    title: 'We set everything up — you don\'t touch a thing',
    body: 'Once you\'re on board: your hosting is migrated or set up fresh. Your Workflow Hub is configured. Your AI tools are connected. Your support person introduces themselves. And at every step: you get full access to your site, your hosting account, and all your logins. Everything is yours from day one.',
  },
  {
    n: '3',
    title: 'Click and comment to update your site',
    body: 'Browse your website. See something that needs changing? Click on it and leave a comment — like a sticky note on a physical document. Our team picks it up and sorts it same-day. No email chain. No quote. No invoice. Most clients say this one feature alone changes how they think about their website.',
  },
  {
    n: '4',
    title: 'Your team keeps the whole thing running',
    body: '24/7. Your support person monitors your site, catches issues before you do, keeps your content current, and replies to anything within the hour. They know your business. They notice when something\'s off. They don\'t wait to be told.',
  },
];

const tools = [
  {
    title: 'Click and comment — the no-jargon way to update your website',
    body: 'Browse your site on any device. Click on anything — a price, a photo, a sentence that\'s wrong. Leave a comment. We handle it same-day. No software to learn, no login to remember, no "open a ticket." You just point at what needs fixing, and your team sorts it.',
    icon: 'M15.042 21.672L13.684 16.6m0 0l-2.51 2.225.569-9.47 5.227 7.917-3.286-.672zM12 2.25V4.5m5.834.166l-1.591 1.591M20.25 10.5H18M7.757 14.743l-1.59 1.59M6 10.5H3.75m4.007-4.243l-1.59-1.59',
  },
  {
    title: 'Your Workflow Hub',
    body: 'All your business systems in one connected place: email management, social scheduling, tasks, communications, reviews, testimonials. Your support person can see what\'s coming in and action it without you having to forward every email or explain every request from scratch.',
    icon: 'M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z',
  },
  {
    title: 'Built to survive anything: Triple-redundant hosting',
    body: 'Three complete copies of your website, running simultaneously. If one goes down — for any reason — another takes over within seconds. Engineered to run at 90%+ capacity with no internet connection, through a power outage, and operable from a mobile phone. For regional businesses and anyone tired of outages killing a Saturday.',
    icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01',
  },
  {
    title: 'Your support person',
    body: 'Not a chatbot. Not an overseas call centre. A real person based in Australia who knows your business and has a full team and AI toolkit behind them to get things done without you having to re-explain yourself every time. One person. One contact. No re-explaining.',
    icon: 'M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z',
  },
  {
    title: 'Human in the Loop AI',
    body: 'AI handles the volume work: drafting content, generating social posts, producing image variations, running reports. A human reviews everything before it touches your brand. AI at speed, human quality control. You get the efficiency without the risk of your website sounding like it was written by a robot.',
    icon: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
    link: '/about/human-in-the-loop',
  },
];
---

<Layout
  title="How It Works — Fast Web Guru | Same-Day Updates, Real Australian Support"
  description="How Fast Web Guru actually works — from free AI assessment to same-day website updates and 24/7 Australian support. No jargon. Full ownership from day one."
>
  <!-- HERO -->
  <section class="section-dark py-20 lg:py-28">
    <div class="container max-w-3xl">
      <h1 class="text-white mb-6">Here's exactly what you're getting into.</h1>
      <p class="text-zinc-400 text-xl leading-relaxed">Plain English. No jargon. No surprises. Here's how Fast Web Guru actually works — from the moment you submit your website to the moment your support person sorts something you didn't even know needed fixing.</p>
    </div>
  </section>

  <!-- 4 STEPS -->
  <section class="section-light section-pad">
    <div class="container">
      <h2 class="mb-16">The 4 steps</h2>
      <div class="space-y-16 max-w-3xl">
        {steps.map(step => (
          <div class="flex gap-8 items-start">
            <div class="step-number flex-shrink-0 w-20 text-right">{step.n}</div>
            <div class="border-l-2 border-brand-border pl-8 flex-1">
              <h3 class="font-bold text-2xl mb-4">{step.title}</h3>
              <p class="text-brand-text-secondary text-lg leading-relaxed">{step.body}</p>
              {step.cta && (
                <a href="/#assessment" class="btn-primary mt-6 inline-flex">Get Your Free AI Assessment</a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TOOLS SECTION -->
  <section class="section-mid section-pad">
    <div class="container">
      <div class="max-w-2xl mb-12">
        <h2 class="mb-4">What we set up. What it does. Why it matters.</h2>
        <p class="text-brand-text-secondary text-lg">Every tool is set up for you. Here's plain English on what each one does.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {tools.map(tool => (
          <div class="bg-brand-surface rounded-lg p-8 border border-brand-border">
            <div class="w-10 h-10 flex items-center justify-center rounded-md bg-orange-50 mb-5">
              <svg class="w-5 h-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                <path stroke-linecap="round" stroke-linejoin="round" d={tool.icon} />
              </svg>
            </div>
            <h3 class="font-bold text-lg mb-3">{tool.title}</h3>
            <p class="text-brand-text-secondary text-sm leading-relaxed">{tool.body}</p>
            {tool.link && (
              <a href={tool.link} class="btn-ghost text-sm mt-4">
                Learn how it works →
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COMMON QUESTIONS -->
  <section class="section-light section-pad">
    <div class="container max-w-3xl">
      <h2 class="mb-12">Common questions</h2>
      <div class="space-y-8">
        {[
          { q: '"Is this going to be complicated to set up?"', a: 'No. We do the setup. You answer a few questions about your business and introduce us to your website. Most clients are running within a couple of days.' },
          { q: '"What if something breaks during migration?"', a: 'We run your new setup in parallel before we touch your live site. Your current website stays up throughout. When the new one is ready, we switch — and your old one stays in backup until you\'re satisfied.' },
          { q: '"Do I own everything? What if I want to leave?"', a: 'Yes, you own everything. Site, domain, all logins — all yours from day one. If you leave, you take it with you. We\'d rather earn your business than hold it.' },
          { q: '"What does the 1-hour response actually cover?"', a: 'Anything you raise with your support person, 6am–10pm, 7 days a week. That includes weekends and evenings — not just business hours.' },
          { q: '"My developer already handles my website."', a: 'We work alongside your developer. We handle the routine updates, hosting resilience, and marketing output so your developer can focus on the work that actually needs them.' },
        ].map(qa => (
          <div class="border-b border-brand-border pb-8">
            <h3 class="font-bold text-lg mb-3 text-brand-dark">{qa.q}</h3>
            <p class="text-brand-text-secondary leading-relaxed">{qa.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="section-dark py-16">
    <div class="container max-w-2xl text-center">
      <h2 class="text-white mb-6">Seen enough?</h2>
      <p class="text-zinc-400 text-lg mb-8">Get a personalised AI assessment of your website — specific findings, no generic advice, no sales call.</p>
      <a href="/#assessment" class="btn-primary text-base py-4 px-10">Get Your Free AI Assessment</a>
    </div>
  </section>
</Layout>
