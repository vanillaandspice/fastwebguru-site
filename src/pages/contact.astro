---
import Layout from '../layouts/Layout.astro';
export const prerender = true;
---

<Layout
  title="Contact — Fast Web Guru | Let's Have a Real Conversation"
  description="No scripts. No sales pitch. Just an honest talk about your business and what's possible. Based in the Hunter Valley, serving businesses across Australia."
>
  <section class="section-dark py-20 lg:py-24">
    <div class="container max-w-2xl">
      <h1 class="text-white mb-4">Let's have a real conversation.</h1>
      <p class="text-zinc-400 text-xl leading-relaxed">No scripts. No sales pitch. Just an honest talk about your business and what's possible.</p>
    </div>
  </section>

  <section class="section-light section-pad">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 max-w-4xl">
        <!-- Left: intro -->
        <div>
          <p class="text-brand-text-secondary text-lg leading-relaxed mb-6">We're based across Australia — Hunter Valley, Newcastle, Sydney, Melbourne, and the Yarra Valley. We reply fast. If you've got a question before you do anything, just ask — we genuinely prefer a real conversation to a form submission.</p>
          <p class="text-brand-text-secondary text-lg leading-relaxed mb-10">Fill in the form and we'll get back to you within 24 hours. Or if you'd rather start with something specific, hit the assessment button below — we'll look at your website first and send you useful information to work from.</p>

          <!-- What happens next -->
          <div class="callout-box">
            <p class="font-bold text-brand-dark mb-2">What happens next</p>
            <p class="text-brand-text-secondary text-sm leading-relaxed">You'll hear back within 24 hours — usually faster. We'll have looked at your website if you provided it, and we'll come with something worth saying.</p>
          </div>

          <div class="mt-8">
            <p class="font-semibold text-brand-dark mb-3">Rather we look at your website first?</p>
            <a href="/#assessment" class="btn-ghost text-base">Get Your Free AI Assessment →</a>
          </div>
        </div>

        <!-- Right: form -->
        <div>
          <form
            name="contact"
            method="POST"
            action="/api/contact"
            class="space-y-5"
            novalidate
            id="contact-form"
          >
            <div>
              <label for="contact-name" class="block text-sm font-medium text-zinc-700 mb-1.5">Your name</label>
              <input type="text" id="contact-name" name="name" required autocomplete="name" placeholder="Jane Smith" class="input" />
            </div>
            <div>
              <label for="contact-business" class="block text-sm font-medium text-zinc-700 mb-1.5">Business name</label>
              <input type="text" id="contact-business" name="business" autocomplete="organization" placeholder="Jane's Bakehouse" class="input" />
            </div>
            <div>
              <label for="contact-email" class="block text-sm font-medium text-zinc-700 mb-1.5">Email address</label>
              <input type="email" id="contact-email" name="email" required autocomplete="email" placeholder="jane@yourbusiness.com.au" class="input" />
            </div>
            <div>
              <label for="contact-url" class="block text-sm font-medium text-zinc-700 mb-1.5">Your website URL <span class="text-zinc-400 font-normal">(optional)</span></label>
              <input type="url" id="contact-url" name="url" autocomplete="url" placeholder="https://yourbusiness.com.au" class="input" />
            </div>
            <div>
              <label for="contact-topic" class="block text-sm font-medium text-zinc-700 mb-1.5">What can we help with?</label>
              <select id="contact-topic" name="topic" class="input cursor-pointer">
                <option value="" disabled selected>Select a topic</option>
                <option value="hosting">Website hosting</option>
                <option value="build">New website build</option>
                <option value="cortex">Cortex AI</option>
                <option value="partner">Partner program</option>
                <option value="other">Something else</option>
              </select>
            </div>
            <div>
              <label for="contact-message" class="block text-sm font-medium text-zinc-700 mb-1.5">Anything else you want us to know <span class="text-zinc-400 font-normal">(optional)</span></label>
              <textarea id="contact-message" name="message" rows="4" placeholder="Tell us anything that's useful context..." class="input resize-y"></textarea>
            </div>

            <button type="submit" class="btn-primary w-full justify-center text-base py-4">
              Send it through
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const name    = (form.querySelector('[name="name"]')    as HTMLInputElement)?.value.trim();
    const email   = (form.querySelector('[name="email"]')   as HTMLInputElement)?.value.trim();
    const business= (form.querySelector('[name="business"]')as HTMLInputElement)?.value.trim();
    const topic   = (form.querySelector('[name="topic"]')   as HTMLSelectElement)?.value;
    const message = (form.querySelector('[name="message"]') as HTMLTextAreaElement)?.value.trim();

    if (!name || !email) return;

    // TODO: Replace with live email API endpoint
    const subject = encodeURIComponent(`FWG Contact: ${topic || 'General enquiry'}`);
    const body    = encodeURIComponent(
      `Name: ${name}\nBusiness: ${business || '—'}\nEmail: ${email}\nTopic: ${topic || '—'}\n\n${message || ''}`
    );
    window.location.href = `mailto:hello@fastwebguru.com?subject=${subject}&body=${body}`;

    form.innerHTML = `<div class="text-center py-12">
      <p class="text-brand-accent text-5xl mb-4">✓</p>
      <h3 class="font-heading font-bold text-2xl mb-2">Got it — thanks.</h3>
      <p class="text-brand-text-secondary">We'll be in touch within 24 hours.</p>
    </div>`;
  });
</script>
