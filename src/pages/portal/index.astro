---
import Layout from '../../layouts/Layout.astro';
import TopBar from '../../components/portal/TopBar.astro';
import CategorySection from '../../components/portal/CategorySection.astro';
import PortalIcon from '../../components/portal/PortalIcon.astro';
import manifest from '../../data/portal-manifest.json';
import { Image } from 'astro:assets';
import opsGridLogo from '../../assets/cortex/cortex-ops-grid.png';
import teamStackLogo from '../../assets/cortex/cortex-team-stack.png';
import hostSystemsLogo from '../../assets/cortex/cortex-host-systems.png';

const { site, categories, assets } = manifest;
const assetsByCategory = (id: string) => assets.filter((a) => a.category === id);
const totalDocs = assets.length;
---
<Layout
  title="Client Portal — Fast Web Guru"
  description="Your Cortex Ops Grid: the living brain of your business. Browse, read, and edit every asset we've built for you."
  noindex={true}
>
  <div class="section-light">
    <div class="container section-pad">
      <!-- Header -->
      <div class="max-w-2xl mx-auto text-center">
        <Image src={opsGridLogo} alt="Cortex Ops Grid" width={500} class="w-60 sm:w-72 lg:w-80 h-auto mx-auto mb-8" />
        <h1 class="mb-4">Your business brain, in one place.</h1>
        <p class="text-lg text-brand-text-secondary">
          Everything we've built for you — your words, your strategy, your campaigns —
          organised and ready. Browse it, read it, and edit any of it in Google Docs with a click.
          <span class="text-brand-text-muted">{totalDocs} documents across {categories.length} areas.</span>
        </p>
      </div>

      <!-- Site / status cluster (centered, just above search) -->
      <div class="mt-10">
        <TopBar site={site} />
      </div>

      <!-- Search -->
      <div class="mt-8 relative max-w-2xl mx-auto">
        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-brand-text-muted pointer-events-none">
          <PortalIcon name="search" class="w-5 h-5" />
        </span>
        <input
          id="portal-search"
          type="search"
          autocomplete="off"
          placeholder="Search your assets… try “pricing”, “brand voice”, or “ads”"
          class="input pl-12 pr-4 py-4 text-base"
          aria-label="Search your assets"
        />
      </div>

      <!-- Master nav (category chips) -->
      <nav class="mt-5 flex flex-wrap gap-2 justify-center" aria-label="Jump to a category">
        <button type="button" data-filter="all" class="portal-chip is-active">All</button>
        {categories.map((c) => (
          <button type="button" data-filter={c.id} class="portal-chip">{c.label}</button>
        ))}
      </nav>

      <!-- No results -->
      <p id="portal-no-results" class="hidden mt-10 text-brand-text-secondary">
        No matches for “<span id="portal-query"></span>”. Try a topic like
        <em>pricing</em>, <em>brand voice</em>, or <em>ads</em> — or
        <button type="button" id="portal-clear" class="text-brand-accent font-semibold underline underline-offset-2">clear the search</button>.
      </p>

      <!-- Category sections -->
      <div class="mt-12 space-y-16" id="portal-sections">
        {categories.map((c) => (
          <CategorySection category={c} assets={assetsByCategory(c.id)} />
        ))}
      </div>

      <!-- The other two pillars (clean, no panels) -->
      <div class="mt-28 pt-16 border-t border-brand-border text-center">
        <h2 class="text-2xl font-heading font-bold text-brand-dark m-0">The other two pillars of your brain</h2>
        <p class="text-brand-text-secondary mt-3 max-w-content mx-auto leading-relaxed">
          This dashboard is your <strong class="text-brand-dark">Ops Grid</strong> — where your strategy lives and gets done.
          It works hand in hand with the other two parts of Cortex.
        </p>
        <div class="mt-16 grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-20 max-w-3xl mx-auto">
          <a href="/cortex/team-stack" class="group flex flex-col items-center px-4 rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent focus-visible:ring-offset-4">
            <Image src={teamStackLogo} alt="Cortex Team Stack" width={420} class="w-44 sm:w-56 h-auto transition-transform duration-300 group-hover:-translate-y-1.5" />
            <span class="mt-8 inline-flex items-center gap-1.5 font-heading font-bold text-brand-dark group-hover:text-brand-accent transition-colors">
              Explore Team Stack
              <PortalIcon name="arrow" class="w-4 h-4 text-brand-accent" />
            </span>
            <span class="block text-sm text-brand-text-secondary mt-2 max-w-xs">Your Business DNA and AI brain — the intelligence that knows your business.</span>
          </a>
          <a href="/cortex/host-systems" class="group flex flex-col items-center px-4 rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent focus-visible:ring-offset-4">
            <Image src={hostSystemsLogo} alt="Cortex Host Systems" width={420} class="w-44 sm:w-56 h-auto transition-transform duration-300 group-hover:-translate-y-1.5" />
            <span class="mt-8 inline-flex items-center gap-1.5 font-heading font-bold text-brand-dark group-hover:text-brand-accent transition-colors">
              Explore Host Systems
              <PortalIcon name="arrow" class="w-4 h-4 text-brand-accent" />
            </span>
            <span class="block text-sm text-brand-text-secondary mt-2 max-w-xs">Your AI-native hosting — edit your live site just by asking.</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .portal-chip {
    @apply inline-flex items-center text-sm font-semibold px-4 py-2 rounded-full border border-brand-border text-brand-text-secondary bg-white transition-colors duration-150;
  }
  .portal-chip:hover { @apply border-brand-accent text-brand-dark; }
  .portal-chip.is-active { @apply bg-brand-dark text-white border-brand-dark; }
</style>

<script>
  // Cmd/Ctrl-K focuses search — bound once at the document level.
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
      e.preventDefault();
      document.getElementById('portal-search')?.focus();
    }
  });

  // Re-run on every page load AND after Astro View Transitions, so the filter
  // and row toggles work even when /portal is reached via a client-side nav.
  function initPortal() {
    const search = document.getElementById('portal-search') as HTMLInputElement | null;
    const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('.portal-chip'));
    const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-asset-card]'));
    const sections = Array.from(document.querySelectorAll<HTMLElement>('[data-category-section]'));
    if (!cards.length) return;
    const noResults = document.getElementById('portal-no-results');
    const queryOut = document.getElementById('portal-query');
    const clearBtn = document.getElementById('portal-clear');

    let activeFilter = 'all';

    function apply() {
      const q = (search?.value || '').trim().toLowerCase();
      let anyVisible = false;

      cards.forEach((card) => {
        const matchesText = !q || (card.dataset.search || '').includes(q);
        const matchesCat = activeFilter === 'all' || card.dataset.category === activeFilter;
        const show = matchesText && matchesCat;
        card.classList.toggle('hidden', !show);
        if (show) anyVisible = true;
      });

      // Hide a category section when none of its rows are visible.
      sections.forEach((sec) => {
        const visible = sec.querySelectorAll('[data-asset-card]:not(.hidden)').length;
        sec.classList.toggle('hidden', visible === 0);
      });

      if (noResults && queryOut) {
        noResults.classList.toggle('hidden', anyVisible);
        queryOut.textContent = q;
      }
    }

    function setFilter(filter: string) {
      activeFilter = filter;
      chips.forEach((c) => c.classList.toggle('is-active', c.dataset.filter === filter));
      apply();
    }

    search?.addEventListener('input', apply);
    chips.forEach((chip) => chip.addEventListener('click', () => setFilter(chip.dataset.filter || 'all')));
    clearBtn?.addEventListener('click', () => {
      if (search) search.value = '';
      setFilter('all');
      search?.focus();
    });

    // Expand / collapse each row's "what's inside" via the info (i) icon.
    document.querySelectorAll<HTMLButtonElement>('.asset-toggle').forEach((btn) => {
      btn.addEventListener('click', () => {
        const row = btn.closest('[data-asset-card]');
        const detail = row?.querySelector('.asset-detail');
        const open = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!open));
        detail?.classList.toggle('hidden', open);
      });
    });
  }

  document.addEventListener('astro:page-load', initPortal);
</script>
