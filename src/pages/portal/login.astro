---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { createSupabaseServer, createSupabaseAdmin } from '../../lib/supabase';

// Already signed in? Send them where they belong.
const supabase = createSupabaseServer(Astro);
const { data: { user } } = await supabase.auth.getUser();
if (user?.email) {
  const admin = createSupabaseAdmin();
  const { data: m } = await admin
    .from('client_users').select('client_id').eq('email', user.email).maybeSingle();
  return Astro.redirect(m ? '/portal' : '/portal/no-access');
}
const hasError = Astro.url.searchParams.has('error');
---
<Layout
  title="Client Portal — Sign in | Fast Web Guru"
  description="Sign in to your Fast Web Guru client portal."
  noindex={true}
>
  <section class="section-dark min-h-[70vh] flex items-center">
    <div class="container max-w-md text-center">
      <span class="chip mb-5">Client Portal</span>
      <h1 class="text-white text-3xl lg:text-4xl mb-3">Sign in to your portal</h1>
      <p class="text-zinc-400 mb-8">Use the Google account we set your portal up with.</p>

      {hasError && (
        <p class="text-sm text-red-400 mb-6">Sorry — that didn't work. Please try signing in again.</p>
      )}

      <form method="POST" action="/portal/auth/signin" data-astro-reload>
        <button type="submit" class="btn-primary w-full justify-center text-base py-4">
          <svg class="w-5 h-5" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.76h3.56c2.08-1.92 3.28-4.74 3.28-8.09Z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.56-2.76c-.98.66-2.23 1.06-3.72 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23Z"/>
            <path fill="#FBBC05" d="M5.84 14.11a6.6 6.6 0 0 1 0-4.22V7.05H2.18a11 11 0 0 0 0 9.9l3.66-2.84Z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1A11 11 0 0 0 2.18 7.05l3.66 2.84C6.71 7.31 9.14 5.38 12 5.38Z"/>
          </svg>
          Continue with Google
        </button>
      </form>

      <p class="text-xs text-zinc-500 mt-6">Access is by invitation. If your email isn't recognised, contact your Fast Web Guru team.</p>
    </div>
  </section>
</Layout>
