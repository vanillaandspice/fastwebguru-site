---
import Layout from '../layouts/Layout.astro';
export const prerender = true;
---

<Layout
  title="Join the Fast Web Guru Team | Roles in Web, Marketing & AI"
  description="Fast Web Guru is growing. Technology Advocates, referral partners, interns, and specialist contractors — see current opportunities."
>
  <!-- Hero -->
  <section class="section-dark py-20 lg:py-28">
    <div class="container max-w-3xl">
      <h1 class="text-white mb-6">Make a Difference. Join Our Team.</h1>
      <p class="text-zinc-400 text-xl leading-relaxed">We're helping Australian small businesses get more out of the web — with real human support and genuine AI that works. If that sounds like something you'd like to be part of, here's how.</p>
    </div>
  </section>

  <!-- Role cards -->
  <section class="section-light section-pad">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">

        <div class="bg-brand-surface border border-brand-border rounded-lg p-8">
          <h2 class="text-xl font-bold text-brand-dark mb-3">Technology Advocate</h2>
          <p class="text-brand-text-secondary leading-relaxed mb-4">Help Australian small businesses understand and use digital tools to grow. This is a flexible, self-employed role suited to people who love technology and genuinely enjoy explaining things simply.</p>
          <ul class="space-y-2 text-sm text-brand-text-secondary">
            <li class="flex gap-2"><svg class="w-4 h-4 text-brand-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>Flexible, self-employed arrangement</li>
            <li class="flex gap-2"><svg class="w-4 h-4 text-brand-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>Work from anywhere</li>
            <li class="flex gap-2"><svg class="w-4 h-4 text-brand-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>Commission + referral income</li>
          </ul>
        </div>

        <div class="bg-brand-surface border border-brand-border rounded-lg p-8">
          <h2 class="text-xl font-bold text-brand-dark mb-3">Referral & Reseller Partner</h2>
          <p class="text-brand-text-secondary leading-relaxed mb-4">Already working with small businesses — in accounting, real estate, trades, or another field? Add Fast Web Guru to your offering and earn monthly passive income for every client you refer.</p>
          <ul class="space-y-2 text-sm text-brand-text-secondary">
            <li class="flex gap-2"><svg class="w-4 h-4 text-brand-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>Passive monthly income per active client</li>
            <li class="flex gap-2"><svg class="w-4 h-4 text-brand-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>No technical knowledge required</li>
            <li class="flex gap-2"><svg class="w-4 h-4 text-brand-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg><a href="/referrals" class="text-brand-accent hover:underline">See the Referral Program →</a></li>
          </ul>
        </div>

        <div class="bg-brand-surface border border-brand-border rounded-lg p-8">
          <h2 class="text-xl font-bold text-brand-dark mb-3">Internship Program</h2>
          <p class="text-brand-text-secondary leading-relaxed mb-4">For students and recent graduates in IT, web development, or marketing who want real-world experience on live client projects — not busy work.</p>
          <ul class="space-y-2 text-sm text-brand-text-secondary">
            <li class="flex gap-2"><svg class="w-4 h-4 text-brand-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>Real projects, real clients</li>
            <li class="flex gap-2"><svg class="w-4 h-4 text-brand-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>Mentored by experienced team</li>
            <li class="flex gap-2"><svg class="w-4 h-4 text-brand-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>IT and marketing roles available</li>
          </ul>
        </div>

        <div class="bg-brand-surface border border-brand-border rounded-lg p-8">
          <h2 class="text-xl font-bold text-brand-dark mb-3">Specialist Contractor</h2>
          <p class="text-brand-text-secondary leading-relaxed mb-4">Strong skills in web development, graphic design, video production, SEO, or digital marketing? We work with specialist contractors who can integrate with a collaborative, client-focused team.</p>
          <ul class="space-y-2 text-sm text-brand-text-secondary">
            <li class="flex gap-2"><svg class="w-4 h-4 text-brand-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>Web dev, design, video, SEO, marketing</li>
            <li class="flex gap-2"><svg class="w-4 h-4 text-brand-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>Collaborative, quality-focused team</li>
            <li class="flex gap-2"><svg class="w-4 h-4 text-brand-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>Contract basis, project or ongoing</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-warm py-16">
    <div class="container max-w-3xl text-center">
      <h2 class="text-2xl font-bold mb-4">Interested?</h2>
      <p class="text-brand-text-secondary text-lg mb-8">Send us a message and tell us a bit about yourself and the role you're interested in.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/contact" class="btn-primary">Get in Touch →</a>
        <a href="mailto:support@fastwebguru.com" class="btn-secondary">support@fastwebguru.com</a>
      </div>
    </div>
  </section>
</Layout>
