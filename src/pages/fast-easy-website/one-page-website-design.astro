---
import Layout from '../../layouts/Layout.astro';
export const prerender = true;
---

<Layout
  title="Fast Web Guru — Invite Only Offer"
  description="Friends and family offer — not publicly advertised."
  noindex={true}
>
  <!-- Invite-only banner -->
  <div class="bg-brand-accent text-white text-center py-3 px-4">
    <p class="text-sm font-semibold">Invite Only — Friends &amp; Family Offer · This page is for people who've received a personal invitation.</p>
  </div>

  <!-- Hero -->
  <section class="section-dark py-20 lg:py-28">
    <div class="container max-w-3xl">
      <h1 class="text-white mb-6">Your website. Done for you. Today.</h1>
      <p class="text-zinc-400 text-xl leading-relaxed">Everything that makes Fast Web Guru different — available at a special rate for people we know personally.</p>
    </div>
  </section>

  <!-- Features -->
  <section class="section-light section-pad">
    <div class="container">
      <div class="max-w-3xl">
        <h2 class="mb-10">What you get</h2>
        <div class="space-y-6">
          {[
            { title: 'Same-day updates', body: 'Point at what needs changing, leave a comment. Done same day, no invoice.' },
            { title: 'Dedicated support person', body: 'One real Australian person who knows your site and your business.' },
            { title: 'Triple-redundant hosting', body: 'Three copies, automatic failover, 90%+ uptime even through a power outage.' },
            { title: 'Full ownership from day one', body: 'Your site, your domain, all logins — you own it all, immediately.' },
            { title: 'Workflow Hub', body: 'Email, social posts, and communications in one connected place.' },
            { title: 'Domain registration included', body: 'We register and manage your domain as part of the plan.' },
            { title: 'Email setup', body: 'Get you set up with a professional email address on your domain.' },
            { title: 'Live within 72 hours', body: 'Your website up and running within 72 hours of your first payment.' },
          ].map(item => (
            <div class="flex gap-5 pb-6 border-b border-brand-border last:border-0">
              <svg class="w-5 h-5 text-brand-accent flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              <div>
                <h3 class="font-bold text-lg mb-1">{item.title}</h3>
                <p class="text-brand-text-secondary">{item.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Invite-only note -->
  <section class="section-warm py-16">
    <div class="container max-w-3xl">
      <div class="callout-box">
        <p class="font-medium text-brand-dark mb-3">This pricing is by invitation only</p>
        <p class="text-brand-text-secondary leading-relaxed mb-4">This is not advertised publicly. If someone you trust shared this link, this is our way of saying thanks to the people who've been with us from the start.</p>
        <p class="text-brand-text-secondary text-sm">Upgrade to Cortex AI at any time for $30/month more — three AI pillars including Talk-to-Edit, Business DNA, and 20 growth workflows.</p>
      </div>
    </div>
  </section>

  <!-- CTAs -->
  <section class="section-dark py-16">
    <div class="container max-w-3xl text-center">
      <h2 class="text-white mb-8">Ready to get started?</h2>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/contact" class="btn-primary">Get Started — Invite Only →</a>
        <a href="/contact/call-back-request" class="btn-ghost-inverse">Request a Call Back</a>
      </div>
    </div>
  </section>
</Layout>
