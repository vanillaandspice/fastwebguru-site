---
import Layout from '../layouts/Layout.astro';
import CTABlock from '../components/CTABlock.astro';
export const prerender = true;

const faqs = [
  { q: 'What\'s the difference between Core ($40/mo) and Core + Cortex ($70/mo)?', a: 'Core gives you the hosting, same-day updates, and your support person. Cortex ($30/mo more) adds three AI pillars: AI-native hosting with Talk-to-Edit, a Business DNA workshop that trains an AI brain on your specific brand, 20 bespoke growth workflows to work through with your team (more added regularly, plus workshops to skill up your leaders), and 1 hour of dedicated AI Specialist time. If you want AI actively working for your business — not just in the background — Cortex is the upgrade. Advanced clients get Cortex automatically at no extra charge.' },
  { q: 'What exactly is Cortex?', a: 'Cortex is FWG\'s AI ecosystem add-on — $30/month as a complete bundle, three pillars working together. Host Systems gives you AI-native infrastructure with Talk-to-Edit. Team Stack builds your Business DNA and trains a personalised AI brain on it (plus 1 hr/mo AI Specialist). Ops Grid gives you 20 bespoke growth workflows to work through with your team — more added regularly, plus workshops to build your team\'s capability. The pillars are only available as a bundle — each one makes the others more effective. See the full Cortex page for details.' },
  { q: 'Can I get Cortex without being on FWG hosting?', a: 'Yes. Cortex Team Stack (Brand DNA + AI brain + Specialist) and Cortex Ops Grid (20 workflows + ongoing additions) work on any website, on any host. Host Systems\' Talk-to-Edit capability runs at full power on FWG\'s AI-native infrastructure. If you\'re on another host, you get the intelligence and execution pillars immediately — Host Systems upgrades when you move to FWG hosting.' },
  { q: 'Is $40/month the real price, or does it go up later?', a: '$40/month is the real price. It doesn\'t increase after 12 months. It doesn\'t have a "renewal rate." Month-to-month plans cost $40/month. That\'s it.' },
  { q: 'Is there a minimum commitment?', a: 'No minimum. Month one is month one. You can cancel at the end of any month with no fee and no questions.' },
  { q: 'What if I need more than 1 hour of support per month?', a: 'You can purchase additional hours at our standard rate, or upgrade to Advanced. Annual clients can also pool hours across the year.' },
  { q: 'What happens to unused hours?', a: 'Monthly hours are use-it-or-lose-it each calendar month. Annual plans pool for the year — use them in any combination.' },
  { q: 'Do I own my website and domain?', a: 'Yes. Your site is yours. Your domain is yours. You get full login access to everything from day one. If you ever leave, you take it all with you.' },
  { q: 'What does "same-day update" actually mean?', a: 'Comment on your website by 4pm and it\'ll be done same day. We\'re available 6am–10pm, including weekends.' },
  { q: 'What happens if the internet goes down?', a: 'Your site keeps running. Three complete copies of your website run simultaneously, with automatic failover. The system operates at 90%+ capacity even through a power outage or on mobile-only connectivity.' },
  { q: 'Is the AI content reviewed by a real person?', a: 'Every AI output is reviewed by a human specialist before it reaches you. The AI does the production; a person makes sure it\'s right for your brand.' },
  { q: 'Who is my dedicated support person — are they Australian?', a: 'You have the option of employing an Australian based Business Advocate — an experienced Marketer as your key support person (rates from $56 p.h.) or the option most people use for day to day work is the online support team (mainly based in the Philippines) — university qualified graduates specifically trained by Fast Web Guru. Our Australian based senior marketers are often involved behind the scenes doing further quality control.' },
  { q: 'I already have a WordPress site — do I have to start again?', a: 'No. We host and run WordPress sites (standard or WooCommerce) as-is, at the same $40 core price as any other platform — and most migrations happen with zero downtime. You keep the familiar editing you already know, and we handle updates, backups, security, and support. If you ever want a faster, more AI-native front end, we can move you to a headless or full-code build without changing providers.' },
  { q: 'What platforms can you build and host on?', a: 'Three: WordPress (standard or WooCommerce), Headless WordPress (a full-code front end on your WordPress content), and Full Code (our AI-native flagship build). All three host at the same $40 core price. The difference is how much of Cortex\'s live AI site-editing (Talk-to-Edit) runs on top — full power on full-code, scaling down on headless and WordPress. Cortex\'s brain and workflows run fully on every platform.' },
  { q: 'How much is ecommerce, and what does it include?', a: 'Ecommerce hosting is $95/month with Cortex AI included — whether your store runs on WooCommerce or a full-code build. It\'s everything in Core, tuned for store traffic and checkout reliability, with product, stock, and order support built into your same-day updates. This replaced our old separate WooCommerce hosting tiers, so there\'s now one clear price for any store. If you need a full team managing the store every week, that\'s Advanced ($240/mo).' },
  { q: 'Is there a free trial?', a: 'No free trial — but no lock-in either. Month-to-month means you can cancel any time. Start with a free AI assessment of your current site instead.' },
];
---

<Layout
  title="Pricing — Fast Web Guru | From $40/month, No Invoice Per Change"
  description="One price on every platform — WordPress, headless, or full-code. Core from $40/mo, Ecommerce $95/mo (Cortex included), Advanced $240/mo. Add Cortex AI for $30/mo. No invoice per change. No lock-in. See exactly what's included."
>
  <!-- HERO -->
  <section class="section-dark py-20 lg:py-28">
    <div class="container">
      <div class="max-w-3xl">
        <h1 class="text-white mb-6">One fixed price. Everything included. No surprises.</h1>
        <p class="text-zinc-400 text-xl leading-relaxed">Same infrastructure. Same support team. You choose how much support time you need — and whether you want AI tools connected to your business. No feature-locking. Nothing hidden.</p>
      </div>

      <!-- $40 suspicion block -->
      <div class="callout-box mt-10 max-w-2xl">
        <p class="font-heading font-bold text-xl text-brand-dark mb-3">"Hang on — is $40 really the price?"</p>
        <p class="text-brand-text-secondary leading-relaxed">Yes. Here's everything that's included. No setup fee. No per-change fees. No upsells required to make it work. No 48-month lock-in that becomes expensive later. $40 a month, month-to-month, and you can cancel anytime.</p>
        <p class="text-brand-text-secondary leading-relaxed mt-3">We say this upfront because we know how many times Australian small businesses have been stung by pricing that turns into something else. That's not us.</p>
      </div>
    </div>
  </section>

  <!-- SELF-SELECTION -->
  <section class="section-mid py-12">
    <div class="container">
      <h2 class="text-2xl font-bold mb-6">Which plan is right for me?</h2>
      <div class="space-y-4 max-w-2xl">
        {[
          { text: 'I just want my website handled without invoices for every change', plan: 'Core ($40/mo, any platform)', href: '/services/core' },
          { text: 'I want AI tools connected to my business + a digital brain trained on my brand', plan: 'Core + Cortex ($70/mo)', href: '/services/core' },
          { text: 'I run an online store and want it hosted and handled', plan: 'Ecommerce ($95/mo, Cortex included)', href: '#ecommerce' },
          { text: 'I need updates, content, and ecommerce management every week', plan: 'Advanced ($240/mo, Cortex included)', href: '/services/advanced' },
          { text: 'I want the full AI marketing system — research, strategy, and monthly workflows at scale', plan: 'Advanced + AI Extender ($690/mo)', href: '/services/advanced' },
          { text: "I don't have a website yet, or mine needs replacing", plan: 'Website Build (from $1,200 — any framework)', href: '/services/website-builds' },
          { text: 'I just want the AI layer — keeping my existing host', plan: 'Cortex only ($30/mo)', href: '/cortex' },
        ].map(row => (
          <a href={row.href} class="flex items-center gap-4 p-5 bg-brand-surface border border-brand-border rounded-lg hover:border-brand-accent transition-colors group">
            <span class="text-brand-accent font-bold text-xl">→</span>
            <span class="text-brand-text-secondary flex-1">{row.text}</span>
            <span class="font-bold text-brand-dark group-hover:text-brand-accent transition-colors">{row.plan}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CHOOSE YOUR PLATFORM -->
  <section id="platforms" class="section-warm section-pad scroll-mt-20">
    <div class="container">
      <div class="max-w-3xl mb-10">
        <h2 class="mb-4">Every platform. One price. AI that scales with your build.</h2>
        <p class="text-brand-text-secondary text-lg leading-relaxed">A lot of website companies only work one way — their builder, their stack, take it or leave it. We don't. Already have a WordPress site you don't want to rebuild? We'll host and run it. Want the fastest, most AI-native site we can make? We'll build it full-code. Most businesses sit somewhere in between — and we host every option for the <strong class="text-brand-dark">same $40 core price.</strong> What changes between platforms isn't the price; it's how much of our Cortex AI runs on top.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        {[
          {
            name: 'WordPress',
            sub: 'Standard or WooCommerce',
            best: 'Existing WordPress sites, familiar editing, the widest plugin ecosystem.',
            bring: 'Yes — we migrate and host it as-is',
            talk: 'Partial',
            featured: false,
          },
          {
            name: 'Headless WordPress',
            sub: 'Full-code front end + WordPress backend',
            best: 'A fast, modern front end while keeping content editing in WordPress.',
            bring: 'Yes — we rebuild the front end over your content',
            talk: 'Strong',
            featured: false,
          },
          {
            name: 'Full Code',
            sub: 'FWG-native — our flagship',
            best: 'Maximum speed, security, and AI capability — built from the ground up.',
            bring: 'New build (or full migration)',
            talk: 'Full power',
            featured: true,
          },
        ].map(p => (
          <div class:list={['rounded-lg p-6 border flex flex-col', p.featured ? 'bg-brand-dark border-brand-accent' : 'bg-brand-surface border-brand-border']}>
            {p.featured && <span class="chip text-xs mb-3 inline-block self-start">Cortex at full power</span>}
            <h3 class:list={['font-bold text-lg', p.featured ? 'text-white' : 'text-brand-dark']}>{p.name}</h3>
            <p class:list={['text-xs italic mb-4', p.featured ? 'text-zinc-400' : 'text-brand-text-secondary']}>{p.sub}</p>
            <p class:list={['text-sm mb-4 flex-1', p.featured ? 'text-zinc-300' : 'text-brand-text-secondary']}>{p.best}</p>
            <dl class="space-y-2 text-sm">
              <div>
                <dt class:list={['text-xs uppercase tracking-wide', p.featured ? 'text-zinc-400' : 'text-brand-text-secondary']}>Bring your existing site?</dt>
                <dd class:list={[p.featured ? 'text-zinc-200' : 'text-brand-dark']}>{p.bring}</dd>
              </div>
              <div>
                <dt class:list={['text-xs uppercase tracking-wide', p.featured ? 'text-zinc-400' : 'text-brand-text-secondary']}>Core hosting price</dt>
                <dd class:list={['font-semibold', p.featured ? 'text-white' : 'text-brand-dark']}>$40/mo</dd>
              </div>
              <div>
                <dt class:list={['text-xs uppercase tracking-wide', p.featured ? 'text-zinc-400' : 'text-brand-text-secondary']}>Cortex Talk-to-Edit</dt>
                <dd class:list={['font-semibold', p.featured ? 'text-brand-accent' : 'text-brand-dark']}>{p.talk}</dd>
              </div>
              <div>
                <dt class:list={['text-xs uppercase tracking-wide', p.featured ? 'text-zinc-400' : 'text-brand-text-secondary']}>Cortex brain + workflows</dt>
                <dd class:list={[p.featured ? 'text-zinc-200' : 'text-brand-dark']}>Full on every platform</dd>
              </div>
              <div>
                <dt class:list={['text-xs uppercase tracking-wide', p.featured ? 'text-zinc-400' : 'text-brand-text-secondary']}>Ecommerce option</dt>
                <dd class:list={[p.featured ? 'text-zinc-200' : 'text-brand-dark']}>$95/mo · Cortex included</dd>
              </div>
            </dl>
          </div>
        ))}
      </div>

      <div class="callout-box max-w-3xl">
        <p class="font-semibold text-brand-dark mb-1">The honest version</p>
        <p class="text-brand-text-secondary text-sm leading-relaxed">We don't pretend every platform does everything. Full Code is where Cortex runs at full power — Talk-to-Edit anywhere on the page, the fastest load times, the tightest security. WordPress and Headless are fully supported, fully hosted, and fully looked after — Cortex's brain and workflows run at 100% on all of them; only the live AI site-editing scales with how the front end is built. <strong class="text-brand-dark">Pick the platform that fits where your business is today. You can move up later without changing providers.</strong></p>
      </div>
    </div>
  </section>

  <!-- PLAN CARDS -->
  <section class="section-light section-pad">
    <div class="container">
      <!-- Core + Ecommerce + Advanced -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">

        <!-- Core -->
        <div class="bg-brand-surface border border-brand-border rounded-lg p-8">
          <h2 class="text-2xl font-bold mb-1">Core</h2>
          <p class="text-brand-text-secondary mb-6">For businesses that want their website handled — without an invoice for every change.</p>
          <div class="flex items-baseline gap-1 mb-2">
            <span class="font-heading font-extrabold text-5xl">$40</span>
            <span class="text-brand-text-secondary">/month</span>
          </div>
          <p class="text-sm text-brand-text-secondary mb-8">or $400/year — 2 months free, full year's hours immediately</p>

          <ul class="space-y-3 mb-8 list-none p-0">
            {[
              'AI-enhanced hosting on the platform that fits you — WordPress, headless, or full-code (same price on every platform; not a slow shared server)',
              'Same-day website updates via click-and-comment — no quote, no invoice',
              '1 hour of dedicated support per month (use it on anything)',
              'Workflow Hub — email management, social, tasks, communications, all connected',
              'Triple-redundant backup (3 copies of your site, automatic failover)',
              '24/7 monitoring, replies within an hour',
              'Full ownership: your site, your domain, all logins. Yours from day one.',
            ].map(f => (
              <li class="flex items-start gap-2.5">
                <svg class="w-4 h-4 text-brand-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                <span class="text-sm text-brand-text-secondary">{f}</span>
              </li>
            ))}
          </ul>

          <p class="text-sm text-brand-text-secondary mb-5"><strong class="text-brand-dark">Want AI actively working for your business?</strong> Add Cortex for $30/month — three AI pillars, brand-trained brain, 20 bespoke growth workflows to work through with your team. See below.</p>

          <div class="space-y-3">
            <a href="/services/core" class="btn-secondary w-full justify-center">Get Started — $40/month</a>
            <a href="/services/core#cortex" class="btn-primary w-full justify-center">Get Started with Cortex AI — $70/month</a>
            <a href="/#assessment" class="btn-ghost w-full justify-center text-sm">Get Free AI Assessment first →</a>
          </div>
          <p class="text-xs text-center text-brand-text-secondary mt-3">Cancel any month. No lock-in. No setup fee. Runs on the platform of your choice.</p>
        </div>

        <!-- Ecommerce -->
        <div id="ecommerce" class="bg-brand-surface border border-brand-border rounded-lg p-8 scroll-mt-24">
          <h2 class="text-2xl font-bold mb-1">Ecommerce</h2>
          <p class="text-brand-text-secondary mb-2">For online stores that need hosting, updates, and AI — handled, on one fixed price.</p>
          <p class="text-xs text-brand-accent-strong font-semibold mb-6">Cortex included — no extra charge</p>
          <div class="flex items-baseline gap-1 mb-2">
            <span class="font-heading font-extrabold text-5xl">$95</span>
            <span class="text-brand-text-secondary">/month</span>
          </div>
          <p class="text-sm text-brand-text-secondary mb-8">or $950/year — 2 months free</p>

          <p class="text-sm text-brand-text-secondary mb-6">Everything in Core, set up for selling — whether your store runs on <strong class="text-brand-dark">WooCommerce</strong> or a <strong class="text-brand-dark">full-code build.</strong> Product, stock, and order flows are looked after as part of your same-day updates, and Cortex AI is included rather than added on.</p>

          <ul class="space-y-3 mb-8 list-none p-0">
            {[
              'Everything in Core (any platform, same-day updates, 1 hr support, triple-redundant backup, full ownership)',
              'Ecommerce-ready hosting tuned for store traffic and checkout reliability',
              'Cortex AI included — Talk-to-Edit, Brand DNA + AI Specialist, 20 monthly growth workflows (no extra charge)',
              'Product, stock, and order support built into your same-day updates',
            ].map(f => (
              <li class="flex items-start gap-2.5">
                <svg class="w-4 h-4 text-brand-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                <span class="text-sm text-brand-text-secondary">{f}</span>
              </li>
            ))}
          </ul>

          <p class="text-xs text-brand-text-secondary italic mb-5">Replaces our old separate WooCommerce hosting tiers — one clear price, any ecommerce platform, Cortex in the box.</p>

          <a href="/contact" class="btn-primary w-full justify-center">Get Started — $95/month</a>
          <p class="text-xs text-center text-brand-text-secondary mt-3">Cancel any month. No lock-in. Need a full team on the store every week? See Advanced.</p>
        </div>

        <!-- Advanced -->
        <div class="bg-brand-dark border border-brand-border-dark rounded-lg p-8">
          <span class="chip text-xs mb-4 inline-block">Most popular</span>
          <h2 class="text-2xl font-bold text-white mb-1">Advanced</h2>
          <p class="text-zinc-400 mb-2">For stores and businesses that need a proper team on the tools every week — 16 hours of dedicated time.</p>
          <p class="text-xs text-brand-accent font-semibold mb-6">Cortex included — no extra charge</p>
          <div class="flex items-baseline gap-1 mb-2">
            <span class="font-heading font-extrabold text-5xl text-white">$240</span>
            <span class="text-zinc-400">/month</span>
          </div>
          <p class="text-sm text-zinc-400 mb-8">or $2,400/year — 2 months free</p>

          <div class="callout-box mb-6">
            <p class="text-sm font-medium text-brand-dark">Replaces $1,200–$2,400/month of freelance dev time</p>
            <p class="text-xs text-brand-text-secondary mt-1">A freelance developer charges $75–$150/hr. 16 hours is $1,200–$2,400 — for someone not available on weekends, who invoices per job. Fast Web Guru Advanced: same time, plus Cortex AI included, plus 24/7 backup. $240/month.</p>
          </div>

          <ul class="space-y-3 mb-8 list-none p-0">
            {[
              'Everything in Core, on any platform',
              '16 hours of dedicated support per month (4 hrs/week)',
              'Cortex included — AI-native infrastructure, Brand DNA + AI Specialist, 20 growth workflows + ongoing additions (no extra charge)',
              'Full ecommerce management — products, stock, orders, campaigns',
              'AI content and marketing production — social, email, product descriptions — weekly',
              'Full communications management — incoming email, autoreplies, reviews, social',
              'Priority response',
            ].map(f => (
              <li class="flex items-start gap-2.5">
                <svg class="w-4 h-4 text-brand-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                <span class="text-sm text-zinc-300">{f}</span>
              </li>
            ))}
          </ul>

          <a href="/services/advanced" class="btn-primary w-full justify-center mb-3">Get Started — $240/month</a>
          <p class="text-xs text-center text-zinc-400 mt-3">Cancel any month. No lock-in. No setup fee.</p>
        </div>
      </div>

      <!-- Add-ons -->
      <div class="space-y-6 mb-16">
        <h2 class="text-2xl font-bold">Add-ons</h2>

        <!-- Cortex -->
        <div id="cortex" class="bg-brand-surface-mid border border-brand-accent rounded-lg p-8">
          <div class="flex flex-wrap items-center gap-3 mb-1">
            <p class="text-xs font-semibold uppercase tracking-widest text-brand-text-secondary">Available on Core · Included free on Ecommerce &amp; Advanced</p>
          </div>
          <div class="flex items-baseline gap-2 mb-1">
            <h3 class="font-bold text-xl">Cortex</h3>
            <span class="text-brand-accent-strong font-bold">+$30/month</span>
          </div>
          <p class="text-brand-text-secondary mb-6">Three AI pillars. One ecosystem. Add it to your existing plan — or to any website, on any platform, on any host.</p>

          <p class="text-brand-dark font-bold mb-4">$30/month. All three pillars. Bundle only.</p>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
            {[
              {
                name: 'Cortex Host Systems',
                desc: 'AI-native hosting with Talk-to-Edit. Update your site by describing what you want. No builders, no code, no waiting for a developer.',
              },
              {
                name: 'Cortex Team Stack',
                desc: 'Your Business DNA ingested at setup. A personalised Digital Marketing Brain trained on your brand — not generic AI. Plus 1 hour a month of a real AI Specialist.',
              },
              {
                name: 'Cortex Ops Grid',
                desc: '20 bespoke growth workflows built from your Business DNA — work through with your team over the coming months, more added regularly.',
              },
            ].map(pillar => (
              <div class="bg-brand-surface border border-brand-border rounded-lg p-5">
                <h4 class="font-semibold text-sm mb-2">{pillar.name}</h4>
                <p class="text-xs text-brand-text-secondary leading-relaxed">{pillar.desc}</p>
              </div>
            ))}
          </div>

          <p class="text-xs text-brand-text-secondary italic mb-6">Team Stack and Ops Grid run at full capacity on every platform and on any host. Host Systems' Talk-to-Edit scales with your build — partial on WordPress and external hosts, full power on our full-code AI hosting. <a href="/pricing#platforms" class="text-brand-accent-strong underline">See how platforms compare →</a> Already on Ecommerce or Advanced? Cortex is included — nothing extra to pay.</p>

          <p class="text-xs text-brand-text-secondary mb-4">Already on another host? Cortex works there too. <a href="/cortex" class="text-brand-accent-strong underline">Learn more →</a></p>

          <div class="flex flex-wrap gap-3">
            <a href="/services/core#cortex" class="btn-primary">Add Cortex to Your Plan — $30/month</a>
            <a href="/cortex" class="text-brand-accent-strong font-semibold hover:underline self-center">Or see the full Cortex page →</a>
          </div>
        </div>

        <!-- AI Extender -->
        <div class="bg-brand-surface-mid border border-brand-border rounded-lg p-8">
          <div class="flex flex-wrap items-center gap-3 mb-4">
            <p class="text-xs font-semibold uppercase tracking-widest text-brand-text-secondary">Advanced plan only · Cortex included</p>
          </div>
          <div class="flex items-baseline gap-2 mb-1">
            <h3 class="font-bold text-xl">AI Extender: Your Digital Business in a Box</h3>
            <span class="text-brand-accent-strong font-bold">+$450/month</span>
          </div>
          <p class="text-sm text-brand-text-secondary italic mb-4">Your online marketing companion — all the research, strategy, and active workflows you need to lift your online presence to a new level.</p>
          <ul class="space-y-2 list-none p-0">
            {[
              'A complete, customised library of marketing plans built specifically for your business — not templates',
              'Your Digital Brain — an internal AI resource to consult anytime on marketing, advertising, and website strategy',
              'Active monthly marketing workflows, ready to implement when you are',
              'Strategic direction that evolves with your business month by month',
              'Cortex fully included (no extra charge)',
            ].map(f => (
              <li class="flex items-start gap-2.5">
                <svg class="w-4 h-4 text-brand-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                <span class="text-sm text-brand-text-secondary">{f}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Website Builds -->
      <div class="border-2 border-brand-border rounded-lg p-8">
        <h2 class="text-2xl font-bold mb-2">Website Builds</h2>
        <p class="text-brand-text-secondary mb-3">A proper website. AI-editable from day one. Built by humans who review every page.</p>
        <p class="text-brand-text-secondary mb-8"><strong class="text-brand-dark">Built in the framework that suits you</strong> — WordPress, Headless WordPress, or full-code. We'll recommend the right one for your goals, and your site hosts at the same core price whichever way we build it.</p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 mb-8">
          <div>
            <h4 class="font-semibold mb-4 text-brand-text-secondary uppercase text-xs tracking-widest">Standard Websites</h4>
            <ul class="space-y-3 list-none p-0">
              {[
                { price: '$240', desc: "Quick 'n Easy - 24 hr turn-around or quicker!" },
                { price: '$1,200', desc: 'Most business websites — most common starting point' },
