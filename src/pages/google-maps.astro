---
import Layout from '../layouts/Layout.astro';
import CTABlock from '../components/CTABlock.astro';
export const prerender = true;
---

<Layout
  title="Google Business Profile for Small Business — Why It Matters in 2026 | Fast Web Guru"
  description="Why Google Business Profile is essential for every local Australian business — free, generates enquiries, builds reviews, and now includes Gemini AI-powered insights."
>
  <!-- Hero -->
  <section class="section-dark py-20 lg:py-28">
    <div class="container max-w-3xl">
      <div class="chip mb-6">Free tool · Updated 2026</div>
      <h1 class="text-white mb-6">Why Your Google Business Profile Matters More Than Ever</h1>
      <p class="text-zinc-400 text-xl leading-relaxed">If you run a local Australian business and you're not actively managing your Google Business Profile, you're leaving money on the table — every single day.</p>
    </div>
  </section>

  <!-- Benefits -->
  <section class="section-light section-pad">
    <div class="container">
      <div class="max-w-3xl space-y-12">

        <div class="flex gap-5">
          <svg class="w-5 h-5 text-brand-accent flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
          <div>
            <h2 class="text-xl font-bold text-brand-dark mb-3">It's completely free — and it works harder than ever</h2>
            <p class="text-brand-text-secondary leading-relaxed">Most business owners think their website is their main online presence. In local search, your Google Business Profile is often more visible than your site. It shows up in Maps, in the "local pack" at the top of search results, and on mobile — where most searches happen. Zero cost to set up, zero cost to maintain.</p>
          </div>
        </div>

        <div class="flex gap-5">
          <svg class="w-5 h-5 text-brand-accent flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
          <div>
            <h2 class="text-xl font-bold text-brand-dark mb-3">It generates real enquiries and foot traffic</h2>
            <p class="text-brand-text-secondary leading-relaxed">Customers can call you with one tap, get directions, read reviews, and see your latest photos — without ever visiting your website. A well-managed profile with recent reviews and up-to-date information converts browsers into customers faster than almost any other free tool available.</p>
          </div>
        </div>

        <div class="flex gap-5">
          <svg class="w-5 h-5 text-brand-accent flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
          <div>
            <h2 class="text-xl font-bold text-brand-dark mb-3">AI-powered business insights — new in 2026</h2>
            <p class="text-brand-text-secondary leading-relaxed">Google's Gemini AI integration now lets you ask plain-English questions about your profile data — "How did my business perform this month?", "Which photos are getting the most views?", "What are customers asking about?" You get clear, actionable insights without needing to interpret charts yourself.</p>
          </div>
        </div>

        <div class="flex gap-5">
          <svg class="w-5 h-5 text-brand-accent flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
          <div>
            <h2 class="text-xl font-bold text-brand-dark mb-3">New review engagement tools</h2>
            <p class="text-brand-text-secondary leading-relaxed">Google has added emoji reactions on reviews and a Story format for photos — making your profile feel more like a live presence than a static listing. Businesses that stay active on their profile get rewarded with better visibility in local search.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- FWG handles this for you -->
  <section class="section-warm py-12">
    <div class="container max-w-3xl">
      <div class="callout-box">
        <p class="font-medium text-brand-dark mb-2">We handle this for you</p>
        <p class="text-brand-text-secondary leading-relaxed">All Fast Web Guru hosting plans include Google Business Profile setup and management. You don't have to figure it out yourself — we set it up, keep it current, and make sure it's working hard for your business.</p>
        <a href="/pricing" class="inline-block mt-4 text-brand-accent font-semibold hover:underline">See hosting plans →</a>
      </div>
    </div>
  </section>

  <!-- Lead magnet -->
  <section class="section-warm py-12 border-t border-brand-border">
    <div class="container max-w-3xl text-center">
      <h2 class="text-2xl font-bold text-brand-dark mb-4">Get the free step-by-step guide</h2>
      <p class="text-brand-text-secondary text-lg mb-6">Download our free guide to setting up and optimising your Google Business Profile — nine steps, plain English, no account required.</p>
      <a href="/google-maps-pdf-download" class="btn-primary">Download the free guide →</a>
    </div>
  </section>

  <CTABlock />
</Layout>
