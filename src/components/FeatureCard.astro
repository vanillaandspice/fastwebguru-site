---
interface Props {
  icon: string;   // SVG path d= value
  title: string;
  body: string;
  link?: { label: string; href: string };
}
const { icon, title, body, link } = Astro.props;
---

<div class="feature-card flex flex-col gap-4">
  <div class="w-10 h-10 flex items-center justify-center rounded-md bg-orange-50 flex-shrink-0">
    <svg class="w-5 h-5 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
    </svg>
  </div>
  <div>
    <h3 class="text-lg font-bold mb-2 text-brand-dark">{title}</h3>
    <p class="text-brand-text-secondary text-sm leading-relaxed">{body}</p>
    {link && (
      <a href={link.href} class="btn-ghost text-sm mt-3">
        {link.label}
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    )}
  </div>
</div>
