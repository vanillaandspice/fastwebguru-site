---
const year = new Date().getFullYear();

const links = {
  Services: [
    { label: 'Core Plan — $40/mo',      href: '/services/core' },
    { label: 'Advanced Plan — $240/mo', href: '/services/advanced' },
    { label: 'Website Builds',          href: '/services/website-builds' },
    { label: 'Cortex AI',               href: '/cortex' },
    { label: 'Human in the Loop',       href: '/about/human-in-the-loop' },
  ],
  Company: [
    { label: 'How It Works', href: '/how-it-works' },
    { label: 'Pricing',      href: '/pricing' },
    { label: 'About Us',     href: '/about' },
    { label: 'Partners',     href: '/partners' },
    { label: 'Contact',      href: '/contact' },
  ],
};
---

<footer class="bg-brand-dark text-brand-surface border-t border-brand-border-dark">
  <div class="container py-16 lg:py-20">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16">

      <!-- Brand + CTA -->
      <div class="lg:col-span-1">
        <a href="/" aria-label="Fast Web Guru home">
          <img src="/logo-light.png" alt="Fast Web Guru" class="h-8 w-auto mb-6" width="196" height="32" />
        </a>
        <p class="text-zinc-400 text-sm leading-relaxed mb-6 max-w-xs">
          AI-powered website hosting and support for Australian small businesses. Done for you. From $40/month.
        </p>
        <a href="/#assessment" class="btn-primary text-sm py-3 px-6">
          Get Free Assessment
        </a>
      </div>

      <!-- Nav links -->
      <div class="lg:col-span-2 grid grid-cols-2 gap-8">
        {Object.entries(links).map(([group, items]) => (
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-zinc-500 mb-4">{group}</p>
            <ul class="space-y-3 list-none m-0 p-0">
              {items.map(item => (
                <li>
                  <a href={item.href} class="text-sm text-zinc-400 hover:text-white transition-colors duration-150">
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-brand-border-dark">
    <div class="container py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-zinc-500">
        &copy; {year} Fast Web Guru. Australian owned and operated.
      </p>
      <nav class="flex items-center gap-5" aria-label="Legal">
        <a href="/privacy" class="text-xs text-zinc-500 hover:text-zinc-300 transition-colors">Privacy Policy</a>
        <a href="/terms"   class="text-xs text-zinc-500 hover:text-zinc-300 transition-colors">Terms of Service</a>
        <a href="/contact" class="text-xs text-zinc-500 hover:text-zinc-300 transition-colors">Contact</a>
      </nav>
    </div>
  </div>
</footer>
