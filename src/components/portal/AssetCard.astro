---
import PortalIcon from './PortalIcon.astro';

interface Props {
  asset: {
    slug: string;
    displayTitle: string;
    teaser: string;
    summary: string;
    skill: string;
    category: string;
    driveEditUrl: string;
  };
}
const { asset } = Astro.props;

const haystack = [asset.displayTitle, asset.teaser, asset.summary, asset.skill]
  .join(' ').toLowerCase();
const hasEdit = !!asset.driveEditUrl;
const detailId = `detail-${asset.slug}`;
const linkBase =
  'text-brand-text-secondary hover:text-brand-accent transition-colors rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent';
---
<div class="asset-row" data-asset-card data-category={asset.category} data-search={haystack}>
  <div class="flex items-center gap-3 px-2 sm:px-3 py-3 rounded-lg transition-colors hover:bg-brand-surface-mid/50">
    <!-- Actions: subtle text links, to the left of the title -->
    <div class="flex items-center gap-3 shrink-0 text-sm font-medium">
      <a href={`/portal/${asset.slug}`} class={linkBase}>View</a>
      {hasEdit ? (
        <a href={asset.driveEditUrl} target="_blank" rel="noopener" class={`inline-flex items-center gap-1 ${linkBase}`}>
          Edit
          <PortalIcon name="external" class="w-3 h-3" />
        </a>
      ) : (
        <span class="text-brand-text-muted cursor-not-allowed" title="Editable Google Doc is being prepared">Edit</span>
      )}
    </div>

    <span class="w-px h-4 bg-brand-border shrink-0" aria-hidden="true"></span>

    <!-- Title + short description, on one line -->
    <div class="min-w-0 flex-1 flex items-baseline gap-2">
      <span class="font-heading font-bold text-brand-dark leading-snug whitespace-nowrap">{asset.displayTitle}</span>
      <span class="hidden sm:block text-sm text-brand-text-secondary truncate">{asset.teaser}</span>
    </div>

    <!-- Info: subtle (i) toggle for the full detail, right of the description -->
    <button
      type="button"
      class="asset-toggle shrink-0 text-brand-text-muted hover:text-brand-accent aria-expanded:text-brand-accent transition-colors rounded-full p-1.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent"
      aria-expanded="false"
      aria-controls={detailId}
      aria-label={`More about ${asset.displayTitle}`}
    >
      <PortalIcon name="info" class="w-5 h-5" />
    </button>
  </div>

  <!-- What's inside -->
  <div id={detailId} class="asset-detail hidden pl-3 pr-10 pb-4 -mt-1">
    <p class="text-sm text-brand-text-secondary leading-relaxed max-w-content border-l-2 border-brand-accent/40 pl-4 m-0">
      {asset.summary}
    </p>
  </div>
</div>
