---
import AssetCard from './AssetCard.astro';
import PortalIcon from './PortalIcon.astro';

interface Props {
  category: { id: string; number: string; label: string; subline: string; icon: string };
  assets: any[];
}
const { category, assets } = Astro.props;

const primary = assets.filter((a) => a.isLatest !== false);
const older = assets.filter((a) => a.isLatest === false);
---
<section id={`cat-${category.id}`} data-category-section={category.id} class="scroll-mt-24">
  <div class="flex items-center gap-3 mb-6">
    <span class="inline-flex items-center justify-center w-10 h-10 rounded-xl bg-brand-dark text-brand-accent flex-shrink-0">
      <PortalIcon name={category.icon} class="w-5 h-5" />
    </span>
    <div>
      <h2 class="text-2xl font-heading font-bold text-brand-dark leading-none m-0">
        <span class="text-brand-text-muted font-medium mr-1">{category.number}</span> {category.label}
      </h2>
      <p class="text-sm text-brand-text-secondary m-0 mt-1">{category.subline}</p>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {primary.map((asset) => <AssetCard asset={asset} category={category} />)}
  </div>

  {older.length > 0 && (
    <details class="mt-4">
      <summary class="list-none cursor-pointer inline-flex items-center gap-1 text-sm font-semibold text-brand-text-secondary select-none">
        Earlier versions ({older.length})
        <PortalIcon name="chevron" class="w-4 h-4" />
      </summary>
      <ul class="mt-2 list-none m-0 p-0 space-y-1">
        {older.map((a) => (
          <li>
            <a href={`/portal/${a.slug}`} class="inline-flex items-center gap-2 text-sm text-brand-text-secondary hover:text-brand-accent">
              <PortalIcon name="doc" class="w-4 h-4" />
              {a.displayTitle}
            </a>
          </li>
        ))}
      </ul>
    </details>
  )}
</section>
