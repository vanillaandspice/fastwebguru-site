---
interface Props {
  id?: string;
  dark?: boolean;
}
const { id = 'assessment', dark = true } = Astro.props;
---

<form
  id={id}
  class="space-y-4"
  novalidate
>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label for={`${id}-name`} class:list={['block text-sm font-medium mb-1.5', dark ? 'text-zinc-300' : 'text-zinc-700']}>
        Your name
      </label>
      <input
        type="text"
        id={`${id}-name`}
        name="name"
        autocomplete="name"
        required
        placeholder="Jane Smith"
        class:list={[dark ? 'input-dark' : 'input']}
      />
    </div>
    <div>
      <label for={`${id}-email`} class:list={['block text-sm font-medium mb-1.5', dark ? 'text-zinc-300' : 'text-zinc-700']}>
        Email address
      </label>
      <input
        type="email"
        id={`${id}-email`}
        name="email"
        autocomplete="email"
        required
        placeholder="jane@yourbusiness.com.au"
        class:list={[dark ? 'input-dark' : 'input']}
      />
    </div>
  </div>

  <div>
    <label for={`${id}-url`} class:list={['block text-sm font-medium mb-1.5', dark ? 'text-zinc-300' : 'text-zinc-700']}>
      Your website URL
    </label>
    <input
      type="url"
      id={`${id}-url`}
      name="url"
      autocomplete="url"
      required
      placeholder="https://yourbusiness.com.au"
      class:list={[dark ? 'input-dark' : 'input']}
    />
  </div>

  <div>
    <label for={`${id}-type`} class:list={['block text-sm font-medium mb-1.5', dark ? 'text-zinc-300' : 'text-zinc-700']}>
      Business type
    </label>
    <select
      id={`${id}-type`}
      name="business_type"
      required
      class:list={[dark ? 'input-dark' : 'input', 'cursor-pointer']}
    >
      <option value="" disabled selected>Select your business type</option>
      <option value="trades">Trades &amp; Services</option>
      <option value="hospitality">Hospitality &amp; Food</option>
      <option value="retail">Retail &amp; Ecommerce</option>
      <option value="professional">Professional Services</option>
      <option value="other">Other</option>
    </select>
  </div>

  <button type="submit" class="btn-primary w-full justify-center text-base py-4">
    Get Your Free AI Assessment
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
    </svg>
  </button>

  <p class:list={['text-xs text-center', dark ? 'text-zinc-400' : 'text-brand-text-secondary']}>
    No sales call. No lock-in. Your site, your domain, your logins — always yours.
  </p>
</form>

<script>
  // Collect all assessment forms on the page
  document.querySelectorAll('form[id]').forEach(el => {
    const form = el as HTMLFormElement;
    if (!form.querySelector('select[name="business_type"]')) return;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      // Basic validation
      const name  = (form.querySelector('[name="name"]') as HTMLInputElement)?.value.trim();
      const email = (form.querySelector('[name="email"]') as HTMLInputElement)?.value.trim();
      const url   = (form.querySelector('[name="url"]') as HTMLInputElement)?.value.trim();
      const type  = (form.querySelector('[name="business_type"]') as HTMLSelectElement)?.value;

      if (!name || !email || !url || !type) {
        const existing = form.querySelector('.form-error') as HTMLElement;
        const err = existing || (() => {
          const el = document.createElement('p');
          el.className = 'form-error text-red-400 text-sm text-center';
          form.appendChild(el);
          return el;
        })();
        err.textContent = 'Please fill in all fields before submitting.';
        return;
      }

      // TODO: Replace with live Claude API + PageSpeed assessment endpoint
      // For now: show confirmation and open mailto as fallback
      const subject = encodeURIComponent('Free AI Assessment Request');
      const body    = encodeURIComponent(
        `Name: ${name}\nEmail: ${email}\nWebsite: ${url}\nBusiness type: ${type}`
      );
      window.location.href = `mailto:hello@fastwebguru.com?subject=${subject}&body=${body}`;

      form.innerHTML = `
        <div class="text-center py-8">
          <div class="text-brand-accent text-5xl mb-4 font-heading font-black">✓</div>
          <h3 class="font-heading font-bold text-xl mb-2 text-brand-surface">You're in the queue.</h3>
          <p class="text-zinc-400 text-sm">We'll have your personalised assessment in your inbox within 24 hours.</p>
        </div>`;
    });
  });
</script>
