<style>
  .fwg-hero { display:flex; align-items:center; justify-content:center; padding:3rem 2rem 1rem; background:var(--fwg-bg,#1A1A1A); }
  .fwg-mark { height:auto; max-width:100%; overflow:visible; }
</style>

<script>
  import { gsap } from "gsap";
  const root = document.querySelector<HTMLElement>("[data-fwg-hero]");
  if (root) {
    const svg = root.querySelector("svg");
    const mm = gsap.matchMedia();
    mm.add("(prefers-reduced-motion: no-preference)", () => {
      const q = gsap.utils.selector(root);
      gsap.set("#fwg-fast", { autoAlpha: 0, x: -140 });
      gsap.set("#fwg-webguru", { autoAlpha: 0, x: 40 });
      gsap.set("#fwgMB", { attr: { stdDeviation: "22 0" } });
      gsap.set(q(".speed-line"), { autoAlpha: 0, scaleX: 0, x: -70, transformOrigin: "left center" });

      const tl = gsap.timeline({ defaults: { ease: "power3.out" } });
      tl.to(q(".speed-line"), { autoAlpha: 1, scaleX: 1, x: 0, stagger: 0.06, duration: 0.4 })
        .to("#fwg-fast", { autoAlpha: 1, x: 0, duration: 0.6, ease: "back.out(1.5)" }, "-=0.15")
        .to("#fwgMB", { attr: { stdDeviation: "0 0" }, duration: 0.5 }, "<")
        .to(svg, { filter: "drop-shadow(0 0 16px rgba(249,115,22,0.55))", duration: 0.25, yoyo: true, repeat: 1 }, "<")
        .to("#fwg-fast", { scale: 1.03, transformOrigin: "center center", duration: 0.18, yoyo: true, repeat: 1 }, "<")
        .to("#fwg-webguru", { autoAlpha: 1, x: 0, duration: 0.45 }, "-=0.28")
        .to(q(".speed-line"), { autoAlpha: 0, x: 26, duration: 0.5, stagger: 0.04 }, "-=0.12")
        .add(() => { gsap.to("#fwg-logo", { y: -5, duration: 1.9, ease: "sine.inOut", yoyo: true, repeat: -1 }); });

      const boost = () => { gsap.to(q(".speed-line"), { autoAlpha: 0.9, scaleX: 1.35, x: -6, duration: 0.3, overwrite: "auto" }); };
      const reset = () => { gsap.to(q(".speed-line"), { autoAlpha: 0, scaleX: 1, x: 26, duration: 0.5, overwrite: "auto" }); };
      root.addEventListener("mouseenter", boost);
      root.addEventListener("mouseleave", reset);
      return () => { root.removeEventListener("mouseenter", boost); root.removeEventListener("mouseleave", reset); };
    });
  }
</script>
