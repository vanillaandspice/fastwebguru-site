---
interface Props {
  name: string;
  price: string;
  period?: string;
  tagline: string;
  features: string[];
  cta: string;
  ctaHref: string;
  featured?: boolean;
  note?: string;
}
const {
  name, price, period = '/month', tagline, features,
  cta, ctaHref, featured = false, note,
} = Astro.props;
---

<div class:list={[
  'rounded-lg p-8 flex flex-col gap-6 border',
  featured
    ? 'bg-brand-dark text-brand-surface border-brand-border-dark plan-card-featured'
    : 'bg-brand-surface text-brand-dark border-brand-border',
  'transition-shadow duration-300'
]}
  data-plan-card
  data-plan-shimmer={featured ? "true" : undefined}
>
  <div>
    {featured && (<span class="chip text-xs mb-3 inline-block">Most popular</span>)}
    <h3 class:list={['text-xl font-bold mb-1', featured ? 'text-white' : 'text-brand-dark']} style="letter-spacing: -0.015em;">{name}</h3>
    <p class:list={['text-sm leading-snug', featured ? 'text-zinc-400' : 'text-brand-text-secondary']}>{tagline}</p>
  </div>
  <div class="flex items-baseline gap-1.5">
    <span class:list={['font-heading font-extrabold leading-none', featured ? 'text-white' : 'text-brand-dark']}
      style="font-size: clamp(2.5rem, 5vw, 3.5rem); letter-spacing: -0.04em;">{price}</span>
    <span class:list={['text-sm', featured ? 'text-zinc-400' : 'text-brand-text-secondary']}>{period}</span>
  </div>
  <ul class="space-y-3 list-none m-0 p-0 flex-1">
    {features.map(f => (
      <li class="flex items-start gap-2.5">
        <svg class="w-4 h-4 text-brand-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
        </svg>
        <span class:list={['text-sm leading-snug', featured ? 'text-zinc-300' : 'text-brand-text-secondary']}>{f}</span>
      </li>
    ))}
  </ul>
  <a href={ctaHref} class:list={[featured ? 'btn-primary w-full justify-center' : 'btn-secondary w-full justify-center']}>{cta}</a>
  {note && (<p class:list={['text-xs text-center', featured ? 'text-zinc-500' : 'text-zinc-400']}>{note}</p>)}
</div>
